# ─────────────────────────────────────────────────────────────────────────────
# PipraPay — Environment Variable Reference
#
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
#
# Never commit your .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Hostname of the MySQL service (use 'mysql' when running with docker-compose)
DB_HOST=mysql
DB_PORT=3306

# Database name, user, and password
DB_NAME=piprapay
DB_USER=piprapay
DB_PASS=change-me-strong-password

# MySQL root password (used only during initial container setup)
MYSQL_ROOT_PASSWORD=change-me-strong-password

# Table prefix (default: pp_)
DB_PREFIX=pp_

# ── Application ───────────────────────────────────────────────────────────────
# 'live' for production, 'demo' to enable demo mode
APP_MODE=live

# Set to 'on' only temporarily when resetting a forgotten admin password
PASSWORD_RESET=off

# Port to expose the app on (local/dev only; production uses Traefik on 80/443)
APP_PORT=80

# ── First-run admin user (optional) ──────────────────────────────────────────
# If all four variables below are set, the entrypoint will automatically create
# the admin account on first run so you can skip the web installer.
# Leave blank to use the web installer at http://<your-domain>/install/ instead.
ADMIN_NAME=Admin
ADMIN_USER=admin
ADMIN_PASS=change-me-admin-password
ADMIN_EMAIL=admin@example.com

# ── Cron (payment auto-verification) ─────────────────────────────────────────
# The URL the cron sidecar hits every 10 minutes.
# Copy the command from Admin Panel → System Settings → Cron Job.
# For Docker-internal access use the service name 'app':
CRON_URL=http://app/install/?cron=verify

# ── Session security ──────────────────────────────────────────────────────────
# Set to 1 when serving over HTTPS (e.g. production with Traefik).
# Keep at 0 for local HTTP development.
SESSION_COOKIE_SECURE=0

# ── Production only (docker-compose.prod.yml) ────────────────────────────────
# Fully-qualified domain name where PipraPay will be reachable
DOMAIN=pay.example.com

# Email address used by Let's Encrypt for certificate renewal notifications
ACME_EMAIL=admin@example.com

# Docker image to pull on the production server
# Format: ghcr.io/<github-org-or-user>/<repo-name>
IMAGE_NAME=ghcr.io/sharf-shawon/piprapay-v2
IMAGE_TAG=latest

# ── Security note ─────────────────────────────────────────────────────────────
# For production deployments, consider passing sensitive values (DB_PASS,
# MYSQL_ROOT_PASSWORD, ADMIN_PASS) via Docker Secrets (Swarm mode) or an
# external secret manager (e.g. HashiCorp Vault, AWS Secrets Manager) rather
# than plain environment variables, to prevent them from appearing in
# `docker inspect` output or process listings.
